Screen {
    layout: vertical;
}

#chat-log {
    height: 1fr;
    border: none;
    padding: 0;
}

#multiline-preview {
    height: auto;
    border: solid $primary;
    display: none;
    padding: 0 1;
}

#error-bar {
    height: auto;
    color: $error;
    display: none;
    padding: 0 1;
}

MessageUser {
    color: cyan;
    text-style: bold;
    padding: 0 1;
}

MessageThinking {
    color: gray;
    text-style: dim;
    padding: 0 1;
}

MessageToolCall {
    color: yellow;
    padding: 0 1;
}

MessageToolResult {
    text-style: dim;
    padding: 0 1;
}

MessageBotCall {
    color: magenta;
    text-style: bold;
    padding: 0 1;
}

MessageSystem {
    text-style: dim;
    padding: 0 1;
}

CommandInput {
    border: solid $primary;
    padding: 0 1;
}
